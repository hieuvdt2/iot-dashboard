# Server environment variables
# Copy to .env and fill with real values

# MQTT
MQTT_URL=mqtts://your-broker.hivemq.cloud:8883
MQTT_USERNAME=your-username
MQTT_PASSWORD=your-password
MQTT_CLIENT_ID=

# Firebase
FIREBASE_DB_URL=https://your-project-default-rtdb.region.firebasedatabase.app
FIREBASE_SERVICE_ACCOUNT=./smart-garden-firebase.json
# Render (không upload file): dán cả JSON service account vào biến này
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
DEVICE_ID=esp32_01

# CORS — để trống hoặc * = cho phép mọi origin (web + Expo)
# Nhiều origin: http://localhost:3001,http://localhost:3002,https://your-app.vercel.app
CORS_ORIGIN=

# AI Assistant (Gemini hoặc OpenAI — ít nhất một key)
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
